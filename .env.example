# ── Mapbox (client-side) ──────────────────────────────────────────────────────
# Get a free token at https://account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ── DLD Gateway (server-side only — never exposed to browser) ─────────────────
# Consumer key from DLD's own public portal JS — used for server-side API proxy.
# Falls back to the public key automatically; set your own if rate-limited.
DLD_CONSUMER_KEY=lMR2xhC1OyK1t46MgjyVv0W8mit4cGN2

# ── Supabase (add when ready) ─────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Stripe (add when ready) ───────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
